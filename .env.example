# pm-copilot — environment configuration
# Copy this file to .env and configure your provider(s).
#
# In hosted-beta mode, the SERVER does not need any LLM keys configured here:
# users supply their own keys in the browser, encrypted to IndexedDB, and the
# server proxies LLM calls using the per-request `x-llm-key` header.
# The keys below are only needed for self-host / local-dev paths.

# -----------------------------------------------------------------------------
# Primary provider (one of: anthropic | openai | google | perplexity)
# -----------------------------------------------------------------------------
PROVIDER=anthropic

# Anthropic. If unset and `claude --version` works, the server falls back to
# Claude Code subprocess auth (zero-config for local dev).
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1

# Google Gemini
# GOOGLE_API_KEY=

# Perplexity Sonar
# PERPLEXITY_API_KEY=

# -----------------------------------------------------------------------------
# Optional enhancement providers
# -----------------------------------------------------------------------------
# Perplexity for web-grounded News agent (overrides primary's web search)
# PERPLEXITY_API_KEY=

# xAI / Grok — required to enable the Sentiment agent. Without this,
# Sentiment panel tab is greyed out.
# XAI_API_KEY=

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8787
PM_COPILOT_CONFIG=./mcp.config.json

# -----------------------------------------------------------------------------
# Cache
# -----------------------------------------------------------------------------
CACHE_DIR=.cache
BRIEF_CACHE_TTL_MS=600000
POSITIONS_CACHE_TTL_MS=60000

# -----------------------------------------------------------------------------
# CORS (web app origin)
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Admin (cache flush, metrics)
# -----------------------------------------------------------------------------
# ADMIN_TOKEN=
