{
  "name": "pm-copilot",
  "version": "0.1.0-beta.0",
  "private": true,
  "description": "Open-source grounded research desk for prediction-market traders. Multi-venue, multi-LLM, MCP-pluggable. Drops in as a Claude Code skill.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,cyan \"pnpm -F @pm-copilot/web dev\" \"pnpm -F @pm-copilot/server dev\"",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,html}\"",
    "smoke": "pnpm -F @pm-copilot/server smoke",
    "prewarm": "node scripts/prewarm-cache.mjs"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "prettier": "^3.3.3",
    "typescript": "^5.7.0"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
